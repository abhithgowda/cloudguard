# =============================================================================
# CloudGuard .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Virtual environments — never commit these
cloudguard-env/
venv/
env/
.venv/

# Environment variable files
.env
.env.*

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------
# Downloaded provider plugins — huge binary files, always regeneratable with terraform init
.terraform/

# NOTE: .terraform.lock.hcl is intentionally NOT ignored.
# It pins provider versions (e.g. hashicorp/aws v5.100.0) so every
# terraform init uses identical providers. Commit it — Terraform docs say so.

# State files — contain real resource IDs, ARNs, and sometimes secrets
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Plan files
*.tfplan

# Var files with real values — use terraform.tfvars.example as the template
terraform.tfvars

# Crash logs
crash.log
crash.*.log

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -----------------------------------------------------------------------------
# Lambda zip packages (generated by scripts/package_lambdas.sh or archive_file)
# -----------------------------------------------------------------------------
*.zip

# archive_file scratch dirs inside the lambda module (one zip per function,
# regenerated at every terraform plan)
**/.builds/

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
# Never commit credentials
.aws/credentials
*.pem
*.key

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Claude Code — local session files, never commit
# -----------------------------------------------------------------------------
.claude/settings.local.json
.claude/worktrees/

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
# Lambda deployment packages (created during CI/CD)
terraform/environments/dev/*.zip
terraform/environments/prod/*.zip
